{
  "headers": [
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(logs|research|evolution|protocol)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
