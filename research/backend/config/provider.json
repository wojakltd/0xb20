{
  "activeProvider": "playwright",
  "providerOrder": ["playwright", "reader", "rss", "cache", "sample"],
  "refreshIntervalMinutes": 10,
  "requestDelayMs": 900,
  "maxPostsPerAccount": 80,
  "maxCacheItems": 2500,
  "maxPostAgeDays": 30,
  "defaultNetwork": "BASE",
  "playwright": {
    "headless": true,
    "navigationTimeoutMs": 18000,
    "selectorTimeoutMs": 9000,
    "scrollPasses": 24,
    "failureLimitBeforeFallback": 3
  },
  "reader": {
    "timeoutMs": 25000,
    "requestDelayMs": 1200,
    "retries": 2
  },
  "rss": {
    "timeoutMs": 4500,
    "retries": 0,
    "bridgeTemplates": [
      "https://nitter.net/{username}/rss",
      "https://nitter.poast.org/{username}/rss",
      "https://nitter.privacydev.net/{username}/rss",
      "https://rsshub.app/twitter/user/{username}",
      "https://twitrss.me/twitter_user_to_rss/?user={username}"
    ]
  }
}
